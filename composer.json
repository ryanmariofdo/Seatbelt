{
    "name": "judehashane/seatbelt",
    "description": "Opinionated, Production-Ready Laravel Standards—All in One Go",
    "keywords": [
        "laravel",
        "package",
        "standards",
        "pint",
        "phpstan",
        "rector",
        "boilerplate"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Jude Hashane",
            "email": "jhashane@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/Hashane/Seatbelt/issues",
        "source": "https://github.com/Hashane/Seatbelt"
    },
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "laravel/pint": "^1.29",
        "phpstan/phpstan": "^2.2",
        "rector/rector": "^2.5",
        "driftingly/rector-laravel": "^2.5"
    },
    "autoload": {
        "psr-4": {
            "Judehashane\\Seatbelt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Judehashane\\Seatbelt\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Judehashane\\Seatbelt\\SeatbeltServiceProvider"
            ]
        }
    },
    "scripts": {
        "rector": "rector process",
        "rector:test": "rector process --dry-run",
        "analyse": "phpstan analyse --memory-limit=2G",
        "test": "pest",
        "quality": [
            "@rector:test",
            "pint --test",
            "@analyse",
            "@test"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}