{
    "name": "judehashane/blueprint",
    "description": "Opinionated, Production-Ready Laravel Standards—All in One Go",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Jude Hashane",
            "email": "jhashane@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Judehashane\\Blueprint\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Judehashane\\Blueprint\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Judehashane\\Blueprint\\BlueprintServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
